<Window x:Class="WpfSensorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arduino Sensor Monitor" Height="360" Width="480"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- KHUNG KẾT NỐI COM PORT -->
        <GroupBox Header="Kết nối Serial (COM Port)" Grid.Row="0" Margin="0,0,0,15" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Cổng COM:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="cboComPorts" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                <Button x:Name="btnRefresh" Content="🔄" Grid.Column="2" Width="30" Height="28" Margin="0,0,10,0" Click="btnRefresh_Click"/>
                <Button x:Name="btnConnect" Content="Connect" Grid.Column="3" Width="85" Height="28" Margin="0,0,5,0" Background="#FF4CAF50" Foreground="White" FontWeight="Bold" Click="btnConnect_Click"/>
                <Button x:Name="btnDisconnect" Content="Disconnect" Grid.Column="4" Width="85" Height="28" Background="#FFE53935" Foreground="White" FontWeight="Bold" IsEnabled="False" Click="btnDisconnect_Click"/>
            </Grid>
        </GroupBox>

        <!-- KHUNG HIỂN THỊ DỮ LIỆU CẢM BIẾN -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card Nhiệt độ -->
            <Border Grid.Column="0" Background="#FFE1F5FE" BorderBrush="#FF81D4FA" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0" Padding="15">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🌡️ NHIỆT ĐỘ" FontSize="14" FontWeight="Bold" Foreground="#FF0288D1"/>
                    <TextBlock x:Name="txtTemperature" Text="--.-- °C" FontSize="32" FontWeight="Bold" Foreground="#FF01579B" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card Độ ẩm -->
            <Border Grid.Column="1" Background="#FFE8F5E9" BorderBrush="#FFA5D6A7" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0" Padding="15">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="💧 ĐỘ ẨM" FontSize="14" FontWeight="Bold" Foreground="#FF388E3C"/>
                    <TextBlock x:Name="txtHumidity" Text="--.-- %" FontSize="32" FontWeight="Bold" Foreground="#FF1B5E20" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- THANH TRẠNG THÁI -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0" Background="#FFF5F5F5">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Trạng thái: Sẵn sàng kết nối" Foreground="Gray" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>